{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types", "@cloudflare/vitest-pool-workers"]
  },
  "include": ["src", "shared", "test", "vitest.config.ts"],
  // web-DOM render tests import browser code (web/src) and are type-checked under
  // tsconfig.web.json (DOM lib) — never with worker fetch types. Vitest still runs
  // them in the pool-workers harness at runtime (file discovery ignores tsconfig).
  "exclude": ["test/render.review.test.ts", "test/render.mywork.test.ts", "test/render.roadmap.test.ts", "test/triage-map.test.ts"]
}
